# MASEST commerce — environment (Phase 1)
# Crisp live chat webhook (/api/crisp/webhook)
CRISP_WEBHOOK_SECRET= # Crisp plugin hook signing secret. Without it webhook no-ops (200).
CRISP_WEBHOOK_KEY= # Website Hooks are unsigned; set this and use /api/crisp/webhook?key=THIS_VALUE.
MASEST_CRISP_ID= # Optional server-side Website ID guard; should match js/config.js.
CRISP_FALLBACK_COMPANY_ID= # Optional company UUID for routing unmatched Crisp chats into a staff-visible thread.

# Copy to .env (local) and set the same vars in Vercel Project Settings → Environment Variables.
# NEVER commit .env. Service-role key is server-only — never ship it to the browser.

# --- Supabase (Phase 1) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...            # safe for browser (RLS-protected)
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # SERVER ONLY. bypasses RLS. never expose.

# Public app origin (for redirects/emails)
APP_URL=https://masest.co

# --- Stripe (Phase 2 — placeholders) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- Resend transactional email (order confirmation, sent from stripe-webhook) ---
RESEND_API_KEY=
RESEND_FROM=MASEST <noreply@masest.co>   # MUST be a Resend-VERIFIED domain (masest.co is verified), else 422. Used for ORDER/OFFER/QUOTE emails — signup-confirm email is sent by Supabase Auth SMTP, configured separately in the Supabase dashboard.
ORDER_NOTIFY_EMAIL=                            # optional: BCC internal sales on every order
RESEND_WEBHOOK_SECRET=                         # Svix secret from Resend Dashboard -> Webhooks (whsec_...). Verifies /api/resend-webhook. Without it the webhook no-ops (200).

# --- Contact / quote intake (/api/quote — replaces Formspree) ---
SALES_EMAIL=matthew@masest.co                  # where new quote/contact leads are emailed (comma-sep ok). Falls back to ORDER_NOTIFY_EMAIL.
# Apply supabase/schema-quotes.sql once so leads also persist + show in the admin Quotes tab.
# TURNSTILE_SECRET (optional) — if set, /api/quote verifies a cf-turnstile-response when the
# contact form sends one. Soft gate: a missing token never blocks a legitimate submission.
TURNSTILE_SECRET=

# --- Klaviyo marketing email (Phase 4) ---
KLAVIYO_PRIVATE_KEY=pk_...          # SERVER ONLY (newsletter function). never client-side.
KLAVIYO_LIST_ID=                    # the newsletter list ID to subscribe into
# Per-industry nurture lists — each maps to a Klaviyo list with a list-triggered 3-email flow.
# Quote leads are subscribed to the list matching their industry; unmapped/empty -> KLAVIYO_LIST_NURTURE.
KLAVIYO_LIST_OIL_GAS=
KLAVIYO_LIST_MARINE=
KLAVIYO_LIST_MANUFACTURING=
KLAVIYO_LIST_FOOD_BEVERAGE=
KLAVIYO_LIST_HEALTHCARE=
KLAVIYO_LIST_CONSTRUCTION=
KLAVIYO_LIST_MILITARY_GOV=
KLAVIYO_LIST_EDUCATION=
KLAVIYO_LIST_HVAC_WATER=
KLAVIYO_LIST_PLUMBING=
KLAVIYO_LIST_NURTURE=               # fallback list for Other / unspecified industry

# --- QuickBooks Online / Intuit ---
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REALM_ID=
QBO_ENVIRONMENT=sandbox
QBO_REDIRECT_URI=https://masest.co/api/admin/qbo/callback
QBO_OAUTH_STATE_SECRET=
QBO_SYNC_SECRET=
QBO_INCOME_ACCOUNT_ID=
# QuickBooks Payments must be enabled in the connected QBO company for generated NET invoices to show online card/ACH payment options.

# --- Phase 5 dashboards (user + admin) ---
# AUTHORITATIVE staff/admin gate for /api/admin/* and admin.html. Comma-separated, case-insensitive.
# Any signed-in Supabase user whose email is in this list is treated as MASEST staff.
ADMIN_EMAILS=aoaljamal@gmail.com
# RESEND_API_KEY (above) also powers the admin "offer email" blast. Without it, offers are in-app only.

# --- Programs (Stripe subscriptions) ---
# JSON map of program tier -> Stripe recurring price id. Create the prices in Stripe, then set this.
# Empty/unset = the business hub falls back to the request-enrollment message flow.
PROGRAM_PRICES=   # e.g. {"Bronze":"price_...","Silver":"price_...","Gold":"price_...","Platinum":"price_..."}
