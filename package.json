{
  "name": "masest-site",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node tools/check-js.mjs",
    "test": "node --test --test-concurrency=1 tests/*.test.mjs",
    "build": "node tools/cf-build.mjs",
    "verify": "npm run check && npm test && npm run build && npm run verify:site",
    "verify:site": "node tools/verify_site.mjs",
    "serve": "python3 -m http.server 4195",
    "smoke:admin": "playwright test tools/admin-auth-gate.spec.mjs tools/admin-quote-message-flows.spec.mjs --reporter=line",
    "qa:remediation": "playwright test tools/*.spec.mjs --reporter=line",
    "seed": "node tools/seed-products.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "impeccable": "^3.0.3"
  }
}
